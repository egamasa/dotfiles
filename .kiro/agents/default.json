{
  "name": "default",
  "description": "Default agent with auto-approved readonly commands",
  "tools": ["*"],
  "allowedTools": ["read", "web_search", "web_fetch"],
  "resources": [
    "file://.kiro/steering/**/*.md",
    "skill://.kiro/skills/**/SKILL.md"
  ],
  "toolsSettings": {
    "shell": {
      "autoAllowReadonly": true,
      "allowedCommands": [
        "(cd [^&]+ && )?(ls|find|cat|head|tail|wc|grep|diff|file|which|echo|pwd)( .*)?",
        "(cd [^&]+ && )?git (status|diff|log|show|stash list)( .*)?"
      ]
    }
  }
}
